rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for incoming data
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Validations
    function isValidProduct(data) {
      return data.sku is string && data.sku.size() <= 50 &&
             data.name is string && data.name.size() <= 200 &&
             data.wholesalePrice is number && data.wholesalePrice >= 0 &&
             data.retailPrice is number && data.retailPrice >= 0 &&
             data.stock is number;
    }

    function isValidOrder(data) {
      return data.shopkeeperId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.paymentStatus in ['Paid', 'Partial', 'Awaiting'];
    }

    function isValidClient(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.type in ['Wholesale', 'Retail'];
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000 &&
             data.type in ['info', 'success', 'warning', 'error'] &&
             data.read is bool;
    }

    function isValidUser(data) {
      return (data.email == null || data.email is string) &&
             (data.displayName == null || data.displayName is string) &&
             data.role in ['admin', 'shop'] &&
             data.createdAt == request.time;
    }

    // Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (incoming().role == existing().role || isAdmin());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn(); 
      allow write: if isOwner(adminId) && (incoming().authKey == 'LEONE_ADMIN_2026' || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if (isAdmin() || isSignedIn()) && isValidProduct(incoming()) && (
        // Allow shopkeepers to ONLY update stock during orders/restock if we had a specific action, 
        // but for now we'll allow update if signed in for simpler logic, guarded by app logic.
        // Hardening: strictly check fields if shopkeeper.
        (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidClient(incoming());
      allow update: if isSignedIn() && isValidClient(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin(); // Orders usually shouldn't be edited once placed
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /insights/{insightId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // AI-generated, but admins can manage
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
