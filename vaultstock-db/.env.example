# Database
POSTGRES_DB=vaultstock
POSTGRES_USER=vaultstock
POSTGRES_PASSWORD=vaultstock_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vaultstock:vaultstock_password@localhost:5432/vaultstock

# Redis
REDIS_PASSWORD=redis_password
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb
REDIS_URL=redis://:redis_password@localhost:6379

# PGAdmin (Development only)
PGADMIN_EMAIL=admin@vaultstock.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# Auth
JWT_SECRET=change_this_in_production_to_a_long_random_string
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# Admin
ADMIN_AUTH_KEY=LEONE_ADMIN_2026

# AI
GEMINI_API_KEY=your-gemini-api-key

# App
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3001